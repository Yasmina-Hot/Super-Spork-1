{
  "manifest_version": 3,
  "name": "Spork AI",
  "description": "Bring Spork AI to every page — chat, select, summarize, screenshot, and more.",
  "version": "1.0.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "spork@spork.ai",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],
  "sidebar_action": {
    "default_panel": "sidepanel/sidepanel.html",
    "default_title": "Spork AI"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Spork AI"
  },
  "commands": {
    "open-sidepanel": {
      "suggested_key": { "default": "Alt+Shift+S" },
      "description": "Open Spork side panel"
    }
  }
}
