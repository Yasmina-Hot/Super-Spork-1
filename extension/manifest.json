{
  "manifest_version": 3,
  "name": "Spork AI",
  "description": "Bring Spork AI to every page — chat, select, summarize, screenshot, and more.",
  "version": "1.0.0",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "sidePanel",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Spork AI"
  },
  "commands": {
    "open-sidepanel": {
      "suggested_key": { "default": "Alt+Shift+S" },
      "description": "Open Spork side panel"
    },
    "quote-selection": {
      "suggested_key": { "default": "Alt+Shift+Q" },
      "description": "Quote selection in Spork"
    }
  },
  "web_accessible_resources": [{
    "resources": ["icons/*.svg"],
    "matches": ["<all_urls>"]
  }]
}
